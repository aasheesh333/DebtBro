<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Required on Android 13+ (API 33) so the Google Mobile Ads SDK can
         access the Advertising ID used for ad personalization. If this
         permission is removed, the SDK falls back to limited ad serving. -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />

    <!-- P0-2 (2026-07-03): READ_CONTACTS is required by the Split tab's
         "pick from contacts" feature (ContactPickerBottomSheet uses
         ActivityResultContracts.PickContact, which queries
         ContactsContract via the returned URI). The contract returns a
         content URI that the calling app can read WITHOUT a permanent
         runtime grant on most Android versions, but the cursor query on
         the URI fails with SecurityException on some OEM ROMs (Xiaomi /
         Vivo / Oppo) when READ_CONTACTS is not declared AND granted, so
         we declare + request the runtime grant to cover the OEM edge
         cases. minSdk=26 — permission always requires explicit runtime
         grant on API ≥ 23. -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- WRITE_EXTERNAL_STORAGE is required for the legacy CsvExporter
         path on API 26-28 (configures Environment.getExternalStoragePublicDirectory).
         maxSdkVersion=28 means it's silently dropped on API ≥ Q where
         MediaStore handles Downloads without needing this runtime grant.
         The legacy path also requests the permission at runtime; if the
         user denies it, the export fails gracefully with an error toast.
         minSdk was set back to 26 on 2026-07-03 — earlier bump to 29
         broke installs on older devices with "parsing the package failed". -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Removed: VIBRATE - not used; app uses default ringtone/vibration from notification channel -->
    <!-- Removed: RECEIVE_BOOT_COMPLETED - not used; WorkManager handles rescheduling after reboot -->

    <application
        android:name=".DebtBroApp"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DebtPayoffPro.Splash"
        android:networkSecurityConfig="@xml/network_security_config">
        <property
            android:name="android.app.PROPERTY_PAGE_SIZE_COMPAT"
            android:value="16" />
        <meta-data
            android:name="android.content.PRIVACY_POLICY_URL"
            android:value="https://dhanuk.page.gd/DebtBro/Privacy-Policy.html" />
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="${ADMOB_APP_ID}" />
        <!-- OneSignal notification icon + accent color.
             ic_notification is a white silhouette derived from the app logo
             (status-bar small icons MUST be white-on-transparent). The accent
             color matches the app's primary green so the notification tint
             reads as on-brand. Referenced as @drawable to share the same set
             of density-bucketed PNGs produced from essential/logo.png. -->
        <meta-data
            android:name="com.onesignal.NotificationDefaultIconName"
            android:resource="@drawable/ic_notification" />
        <meta-data
            android:name="com.onesignal.NotificationAccentColor.DEFAULT"
            android:value="#00E5A0" />
        <meta-data
            android:name="com.onesignal.NotificationAccentColor"
            android:value="#00E5A0" />
        <property
            android:name="android.adservices.AD_SERVICES_CONFIG"
            android:resource="@xml/gma_ad_services_config"
            tools:replace="android:resource" />
        <meta-data
            android:name="firebase_crashlytics_collection_enabled"
            android:value="true" />
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="remove" />
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="debtbro" android:host="debt" />
            </intent-filter>
        </activity>
    </application>
</manifest>
